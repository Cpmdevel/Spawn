--        WEATHER & MUTATION
-- ==============================
local currentWeather = "Day"
local currentMutations = {}

local function updateWeatherInfo()
    local lighting = game:GetService("Lighting")
    if lighting.ClockTime >= 18 or lighting.ClockTime <= 6 then
        currentWeather = "Night"
    else
        currentWeather = "Day"
    end
    -- Additional weather detection could be added here
end

-- ==============================
--          MAIN LOOP
-- ==============================
local function mainLoop()
    while task.wait(0.5) do
        updateWeatherInfo()
        autoHarvest()
        autoPlant()
        autoWater()
        autoCollect()
        autoSell()
        autoBuy()
    end
end

