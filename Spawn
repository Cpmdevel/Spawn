--[[
    🔥 Grow A Garden 2 - Delta AutoFarm (Fully Upgraded) 🔥
    Works with: Delta Executor (mobile & PC)
    Features:
      ✅ Auto Harvest (radius configurable)
      ✅ Auto Plant (prioritises Rainbow / Gold / Normal based on your choice)
      ✅ Auto Sell
      ✅ Auto Water
      ✅ Auto Collect (rainbow/gold seeds from ground)
      ✅ Auto Buy Seeds
      ✅ Anti‑AFK (jump every 45 seconds)
      ✅ Simple GUI (dragable, toggle buttons)
    
    No external libraries – pure Lua, 100% Delta safe.
    Press [ K ] to toggle the GUI on/off.
]]

-- ==============================
--          SETUP
-- ==============================
local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")
local userInputService = game:GetService("UserInputService")
local virtualUser = game:GetService("VirtualUser")  -- may not work on Delta, but kept for compatibility

-- Settings (adjust via GUI)
local settings = {
    autoHarvest = true,
    autoPlant = true,
    autoSell = true,
    autoWater = true,
    autoCollect = true,
    autoBuy = true,
    antiAFK = true,
    harvestRadius = 35,
    preferredSeed = "Rainbow",   -- "Rainbow", "Gold", "Normal"
    minSeeds = 5
}

-- ==============================
--        HELPER FUNCTIONS
-- ==============================
local function getCharacter()
    return player.Character
end

local function getHumanoidRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- Safe click (works on Delta)
local function clickDetector(detector)
    if detector and detector.Parent then
        pcall(function()
            fireclickdetector(detector)
        end)
        task.wait(0.05)
    end
end

-- Get all ClickDetectors within radius
local function getNearbyClickDetectors(radius)
    local hrp = getHumanoidRootPart()
    if not hrp then return {} end
    local detectors = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            local parent = obj.Parent
            if parent and parent:IsA("BasePart") then
                local distance = (parent.Position - hrp.Position).Magnitude
                if distance <= radius then
                    table.insert(detectors, obj)
                end
            end
        end
    end
    return detectors
end

-- Check if player has a tool (equipped or in backpack)
local function hasTool(toolName)
    local char = getCharacter()
    if char and char:FindFirstChild(toolName) then return true end
    return player.Backpack:FindFirstChild(toolName) ~= nil
end

-- Equip tool from backpack
local function equipTool(toolName)
    local tool = player.Backpack:FindFirstChild(toolName)
    if tool then
        tool.Parent = player.Character
        task.wait(0.3)
        return true
    end
    return false
end

-- Unequip tool back to backpack
local function unequipTool(tool)
    if tool and tool.Parent == player.Character then
        tool.Parent = player.Backpack
        task.wait(0.1)
    end
end

-- ==============================
--        AUTO HARVEST
-- ==============================
local function autoHarvest()
    if not settings.autoHarvest then return end
    local detectors = getNearbyClickDetectors(settings.harvestRadius)
    for _, det in pairs(detectors) do
        local parent = det.Parent
        if parent and (parent.Name:find("Crop") or parent.Name:find("Fruit") or parent.Name:find("Harvest")) then
            clickDetector(det)
        end
    end
end

-- ==============================
--        AUTO PLANT (with preferredSeed)
-- ==============================
local function autoPlant()
    if not settings.autoPlant then return end
    
    local backpack = player.Backpack
    local seeds = {}
    
    -- Collect all seeds from backpack
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:find("Seed") then
            local priority = 0
            local name = tool.Name
            if settings.preferredSeed == "Rainbow" and name:find("Rainbow") then
                priority = 3
            elseif settings.preferredSeed == "Gold" and name:find("Gold") then
                priority = 3
            elseif settings.preferredSeed == "Normal" and (name:find("Normal") or (name:find("Seed") and not name:find("Rainbow") and not name:find("Gold"))) then
                priority = 3
            elseif name:find("Rainbow") then
                priority = 2
            elseif name:find("Gold") then
                priority = 1
            else
                priority = 0
            end
            table.insert(seeds, {tool = tool, priority = priority})
        end
    end
    
    -- Sort by priority (higher first)
    table.sort(seeds, function(a, b) return a.priority > b.priority end)
    
    for _, entry in pairs(seeds) do
        local seed = entry.tool
        -- Equip seed
        seed.Parent = player.Character
        task.wait(0.3)
        
        -- Try remote events (most common)
        local plantRemote = replicatedStorage:FindFirstChild("PlantSeed") or
                            replicatedStorage:FindFirstChild("Plant") or
                            replicatedStorage:FindFirstChild("GrowPlant")
        if plantRemote then
            pcall(function()
                plantRemote:FireServer(seed)
            end)
            task.wait(0.5)
        else
            -- Fallback: click on an empty plot
            local plots = workspace:GetDescendants()
            for _, obj in pairs(plots) do
                if obj:IsA("ClickDetector") and obj.Parent and obj.Parent.Name:find("Plot") then
                    clickDetector(obj)
                    task.wait(0.2)
                    break
                end
            end
        end
        
        -- Unequip seed
        seed.Parent = backpack
        task.wait(0.2)
    end
end

-- ==============================
--        AUTO SELL
-- ==============================
local function autoSell()
    if not settings.autoSell then return end
    
    local sellRemote = replicatedStorage:FindFirstChild("SellItem") or 
                       replicatedStorage:FindFirstChild("SellCrop") or
                       replicatedStorage:FindFirstChild("Sell")
    if not sellRemote then return end
    
    local backpack = player.Backpack
    for _, item in pairs(backpack:GetChildren()) do
        if item:IsA("Tool") and (item.Name:find("Crop") or item.Name:find("Fruit") or item.Name:find("Strawberry") or item.Name:find("Carrot")) then
            pcall(function()
                sellRemote:FireServer(item)
            end)
            task.wait(0.1)
        end
    end
end

-- ==============================
--        AUTO WATER
-- ==============================
local function autoWater()
    if not settings.autoWater then return end
    if not hasTool("WateringCan") then return end
    
    local success = equipTool("WateringCan")
    if not success then return end
    
    local wateringCan = player.Character:FindFirstChild("WateringCan")
    if not wateringCan then return end
    
    local hrp = getHumanoidRootPart()
    if hrp then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:find("Dry") or obj.Name:find("Thirsty") or (obj.Name:find("Plant") and obj:FindFirstChild("WaterLevel"))) then
                local distance = (obj.Position - hrp.Position).Magnitude
                if distance <= 15 then
                    local clickDet = obj:FindFirstChild("ClickDetector")
                    if clickDet then
                        clickDetector(clickDet)
                        task.wait(0.3)
                    end
                end
            end
        end
    end
    
    unequipTool(wateringCan)
end

-- ==============================
--        AUTO COLLECT (Rainbow/Gold Seeds)
-- ==============================
local function autoCollect()
    if not settings.autoCollect then return end
    local detectors = getNearbyClickDetectors(settings.harvestRadius)
    for _, det in pairs(detectors) do
        local parent = det.Parent
        if parent and (parent.Name:find("Rainbow") or parent.Name:find("Gold") or parent.Name:find("Seed")) then
            clickDetector(det)
        end
    end
end

-- ==============================
--        AUTO BUY SEEDS
-- ==============================
local function autoBuy()
    if not settings.autoBuy then return end
    
    -- Count current seeds
    local seedCount = 0
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:find("Seed") then
            seedCount = seedCount + 1
        end
    end
    
    if seedCount < settings.minSeeds then
        local buyRemote = replicatedStorage:FindFirstChild("BuySeed") or
                          replicatedStorage:FindFirstChild("PurchaseSeed") or
                          replicatedStorage:FindFirstChild("Shop")
        if buyRemote then
            local seedType = "NormalSeed"
            if settings.preferredSeed == "Rainbow" then
                seedType = "RainbowSeed"
            elseif settings.preferredSeed == "Gold" then
                seedType = "GoldSeed"
            end
            pcall(function()
                buyRemote:FireServer(seedType)
            end)
            task.wait(0.5)
        end
    end
end

-- ==============================
--        ANTI AFK (Jump method, Delta safe)
-- ==============================
local function antiAFK()
    if not settings.antiAFK then return end
    local character = getCharacter()
    local humanoid = character and character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
    task.wait(45)
    antiAFK()
end

-- ==============================
--          MAIN LOOP
-- ==============================
local function mainLoop()
    while task.wait(0.5) do
        autoHarvest()
        autoPlant()
        autoWater()
        autoCollect()
        autoSell()
        autoBuy()
    end
end

