--[ Grow A Garden 2 - Full AutoFarm (English) ]--
-- Works with most executors (Synapse X, Krnl, Script‑Ware, etc.)

local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local runService = game:GetService("RunService")
local virtualUser = game:GetService("VirtualUser")  -- for anti‑AFK

-- ========== CONFIGURATION ==========
local CONFIG = {
    HarvestRadius = 30,          -- how far to look for harvestable crops
    PlantSeeds = true,           -- auto‑plant seeds from inventory
    SellCrops = true,            -- auto‑sell crops in inventory
    WaterPlants = true,          -- auto‑water nearby plants
    AntiAFK = true,              -- prevent being kicked
    PreferredSeed = "Rainbow",   -- "Rainbow", "Gold", or "Normal"
    LoopDelay = 0.5              -- seconds between main loop actions
}

-- ========== HELPER FUNCTIONS ==========
local function getCharacter()
    return player.Character
end

local function getHumanoidRootPart()
    local char = getCharacter()
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- Find all clickable objects (crops, seeds on ground, water buckets, etc.)
local function getNearbyClickDetectors(radius)
    local hrp = getHumanoidRootPart()
    if not hrp then return {} end
    local detectors = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            local parent = obj.Parent
            if parent and parent:IsA("BasePart") then
                local distance = (parent.Position - hrp.Position).Magnitude
                if distance <= radius then
                    table.insert(detectors, obj)
                end
            end
        end
    end
    return detectors
end

-- Click a ClickDetector (harvest, pick up seed, water, etc.)
local function clickDetector(detector)
    if detector and detector.Parent then
        fireclickdetector(detector)
        wait(0.05)
    end
end

-- Auto‑harvest: click all nearby ClickDetectors
local function autoHarvest()
    local detectors = getNearbyClickDetectors(CONFIG.HarvestRadius)
    for _, det in pairs(detectors) do
        clickDetector(det)
    end
end

-- Auto‑plant: find seeds in backpack and use them
local function autoPlant()
    if not CONFIG.PlantSeeds then return end
    local backpack = player.Backpack
    local tools = backpack:GetChildren()
    -- Sort: preferred seed type first
    local sorted = {}
    for _, tool in pairs(tools) do
        if tool:IsA("Tool") and tool.Name:find("Seed") then
            local name = tool.Name
            local priority = 0
            if name:find(CONFIG.PreferredSeed) then priority = 3
            elseif name:find("Gold") then priority = 2
            elseif name:find("Rainbow") then priority = 1
            else priority = 0 end
            table.insert(sorted, {tool = tool, prio = priority})
        end
    end
    table.sort(sorted, function(a,b) return a.prio > b.prio end)
    
    for _, entry in pairs(sorted) do
        local seed = entry.tool
        -- equip seed
        seed.Parent = player.Character
        wait(0.2)
        -- find a nearby empty plot (via remote event – example)
        -- Many games use ReplicatedStorage:PlantSeed or similar
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("PlantSeed")
        if remote then
            remote:FireServer(seed)
        else
            -- fallback: try to use tool's activation
            local toolScript = seed:FindFirstChild("Script") or seed:FindFirstChild("LocalScript")
            if toolScript then
                -- just equip and let the game handle it
                wait(0.1)
                -- you may need to click the ground: simulate mouse click
                local hrp = getHumanoidRootPart()
                if hrp then
                    local groundPos = hrp.Position + Vector3.new(0, -3, 0)
                    -- fire a fake mouse click (some executors support)
                    -- otherwise just wait
                end
            end
        end
        wait(0.5)
        -- unequip back to backpack
        seed.Parent = backpack
        wait(0.1)
    end
end

-- Auto‑sell: find crops in inventory and sell them
local function autoSell()
    if not CONFIG.SellCrops then return end
    local backpack = player.Backpack
    for _, item in pairs(backpack:GetChildren()) do
        if item:IsA("Tool") and (item.Name:find("Strawberry") or item.Name:find("Carrot") or item.Name:find("Crop")) then
            -- find sell remote
            local sellRemote = game:GetService("ReplicatedStorage"):FindFirstChild("SellItem")
            if sellRemote then
                sellRemote:FireServer(item)
                wait(0.1)
            else
                -- alternative: drag to sell zone via ClickDetector on a sell booth
                for _, det in pairs(workspace:GetDescendants()) do
                    if det:IsA("ClickDetector") and det.Parent and det.Parent.Name:find("Sell") then
                        fireclickdetector(det)
                        wait(0.2)
                        break
                    end
                end
            end
        end
    end
end

-- Auto‑water: find water bucket and use on dry plants
local function autoWater()
    if not CONFIG.WaterPlants then return end
    local backpack = player.Backpack
    local waterTool = nil
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:find("Water") or tool.Name:find("Bucket")) then
            waterTool = tool
            break
        end
    end
    if not waterTool then return end
    
    -- equip water bucket
    waterTool.Parent = player.Character
    wait(0.2)
    
    -- find dry plants (look for a part named "Dry" or a attribute)
    local hrp = getHumanoidRootPart()
    if hrp then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and (obj.Name:find("Dry") or obj.Name:find("Plant") and obj:FindFirstChild("WaterLevel")) then
                local dist = (obj.Position - hrp.Position).Magnitude
                if dist <= 15 then
                    -- click on the dry plant
                    local clickDet = obj:FindFirstChild("ClickDetector")
                    if clickDet then
                        fireclickdetector(clickDet)
                        wait(0.2)
                    end
                end
            end
        end
    end
    
    -- unequip
    waterTool.Parent = backpack
end

-- Anti‑AFK: simulate small input every minute
local function antiAFK()
    if not CONFIG.AntiAFK then return end
    local b = game:GetService("VirtualUser")
    b:CaptureController()
    b:ClickButton1(Vector2.new())
    wait(60)
    antiAFK()
end

-- ========== MAIN LOOP ==========
local function mainLoop()
    while task.wait(CONFIG.LoopDelay) do
        autoHarvest()
        autoPlant()
        autoWater()
        autoSell()
    end
end

-- Start everything
print("Loading Grow A Garden 2 AutoFarm...")
spawn(mainLoop)
if CONFIG.AntiAFK then
    spawn(antiAFK)
end

