-- Toggle buttons (y offset increases)
local yOffset = 40
local function addToggle(text, flag, default)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 30)
    btn.Position = UDim2.new(0.05, 0, 0, yOffset)
    btn.BackgroundColor3 = default and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(150, 50, 50)
    btn.Text = text .. (default and " ✅" or " ❌")
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 13
    btn.Parent = mainFrame
    
    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        settings[flag] = state
        btn.BackgroundColor3 = state and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(150, 50, 50)
        btn.Text = text .. (state and " ✅" or " ❌")
    end)
    yOffset = yOffset + 35
end

