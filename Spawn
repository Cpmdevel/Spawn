-- Grow a Garden 2 Advanced AutoFarm Script
-- Fully automated: Grow All, Seed Buying, Plot Management, Harvesting, Selling
-- Toggle GUI: ON/OFF

-- Services
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local GuiService = game:GetService("GuiService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- State
local isRunning = false
local modulesRunning = false

-- Cached references
local growAllButton = nil
local buyRemote = nil
local plantRemote = nil
local sellPart = nil
local plotsCache = {}
local harvestCache = {}

-- Helper: deep find button by text or name
local function findGrowAllButton()
    local function search(container)
        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("TextButton") or child:IsA("ImageButton") then
                local text = child.Text or child.Name or ""
                if text:find("Grow All") or text:find("GrowAll") or text:find("GROW ALL") then
                    return child
                end
            end
            local found = search(child)
            if found then return found end
        end
        return nil
    end
    return search(playerGui)
end

-- Helper: find buy remote (Bamboo / Strawberry)
local function findBuyRemote()
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") and (obj.Name:find("Buy") or obj.Name:find("Purchase") or obj.Name:find("Seed")) then
            return obj
        end
    end
    return nil
end

-- Helper: find plant remote
local function findPlantRemote()
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") and (obj.Name:find("Plant") or obj.Name:find("Seed") or obj.Name:find("Grow")) then
            return obj
        end
    end
    return nil
end

-- Helper: find sell zone
local function findSellPart()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:find("Sell") or obj.Name:find("SellZone") or obj.Name:find("SellArea")) then
            return obj
        end
    end
    return nil
end

-- Helper: get all soil plot objects
local function getAllPlots()
    local plots = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:find("Plot") or obj.Name:find("Soil") or obj.Name:find("Pot") or obj.Name:find("Bed")) then
            table.insert(plots, obj)
        end
    end
    return plots
end

-- Helper: check if plot is vacant (no child crop/model)
local function isPlotVacant(plot)
    for _, child in ipairs(plot:GetChildren()) do
        if child:IsA("Model") or child:IsA("BasePart") then
            if child.Name:find("Crop") or child.Name:find("Plant") or child.Name:find("Growing") then
                return false
            end
        end
    end
    return true
end

-- Helper: get harvestable crops with proximity prompt or touch interest
local function getHarvestableCrops()
    local crops = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt")
            local touch = obj:FindFirstChildWhichIsA("TouchInterest")
            if (prompt or touch) and (obj.Name:find("Crop") or obj.Name:find("Plant") or obj.Name:find("Harvest")) then
                table.insert(crops, obj)
            end
        end
    end
    return crops
end

-- MODULE 1: Grow All button click every 1.5 sec
local function moduleGrowAll()
    while true do
        if isRunning then
            pcall(function()
                if not growAllButton or not growAllButton.Parent then
                    growAllButton = findGrowAllButton()
                end
                if growAllButton and growAllButton:IsA("GuiButton") then
                    growAllButton:Click()
                elseif growAllButton then
                    growAllButton.MouseButton1Click:Fire()
                end
            end)
        end
        task.wait(1.5)
    end
end

-- MODULE 2: Automated seed buying (Bamboo & Strawberry)
local function moduleBuySeeds()
    local seedsToBuy = {"Bamboo", "Strawberry"}
    while true do
        if isRunning then
            pcall(function()
                if not buyRemote then buyRemote = findBuyRemote() end
                if buyRemote then
                    for _, seedName in ipairs(seedsToBuy) do
                        buyRemote:FireServer(seedName, 1) -- assuming quantity 1
                        task.wait(0.3)
                    end
                end
            end)
        end
        task.wait(1)
    end
end

-- MODULE 3: Plot management & planting
local function modulePlanting()
    while true do
        if isRunning then
            pcall(function()
                if not plantRemote then plantRemote = findPlantRemote() end
                local plots = getAllPlots()
                for _, plot in ipairs(plots) do
                    if isPlotVacant(plot) then
                        if plantRemote then
                            -- try to use available seed types (bamboo/strawberry)
                            plantRemote:FireServer(plot, "Bamboo") -- or Strawberry alternately
                            task.wait(0.2)
                        end
                    end
                end
            end)
        end
        task.wait(0.8)
    end
end

-- MODULE 4: Proximity harvesting
local function moduleHarvesting()
    while true do
        if isRunning then
            pcall(function()
                local crops = getHarvestableCrops()
                for _, crop in ipairs(crops) do
                    local prompt = crop:FindFirstChildWhichIsA("ProximityPrompt")
                    if prompt then
                        prompt:Prompt(player)
                    else
                        local touch = crop:FindFirstChildWhichIsA("TouchInterest")
                        if touch and humanoidRootPart then
                            firetouchinterest(humanoidRootPart, crop, 0)
                            task.wait(0.1)
                            firetouchinterest(humanoidRootPart, crop, 1)
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end
        task.wait(1)
    end
end

-- MODULE 5: Automated selling zone
local function moduleSelling()
    while true do
        if isRunning then
            pcall(function()
                if not sellPart then sellPart = findSellPart() end
                if sellPart and humanoidRootPart then
                    firetouchinterest(humanoidRootPart, sellPart, 0)
                    task.wait(0.2)
                    firetouchinterest(humanoidRootPart, sellPart, 1)
                end
            end)
        end
        task.wait(4)
    end
end

-- GUI Toggle Button
local function createToggleGUI()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AutoFarmGUI"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 150, 0, 50)
    frame.Position = UDim2.new(0, 10, 0, 10)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BackgroundTransparency = 0.2
    frame.BorderSizePixel = 0
    frame.Parent = screenGui

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, -10, 1, -10)
    button.Position = UDim2.new(0, 5, 0, 5)
    button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    button.Text = "AutoFarm: OFF"
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.GothamBold
    button.TextSize = 14
    button.Parent = frame

    button.MouseButton1Click:Connect(function()
        isRunning = not isRunning
        if isRunning then
            button.Text = "AutoFarm: ON"
            button.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        else
            button.Text = "AutoFarm: OFF"
            button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        end
    end)

    -- Draggable functionality
    local dragging = false
    local dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- Start all modules with task.spawn
local function startModules()
    if modulesRunning then return end
    modulesRunning = true
    task.spawn(moduleGrowAll)
    task.spawn(moduleBuySeeds)
    task.spawn(modulePlanting)
    task.spawn(moduleHarvesting)
    task.spawn(moduleSelling)
end

-- Initialize
createToggleGUI()
startModules()
