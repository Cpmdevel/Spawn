            if gui then
                for _, btn in ipairs(gui:GetDescendants()) do
                    if btn:IsA("TextButton") or btn:IsA("ImageButton") then
                        local t = (btn.Text or ""):lower()
                        if t:find("sell") or t:find("cash in") or t:find("collect money") or t:find("harvest all") then
