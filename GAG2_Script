--[[
    GROW A GARDEN 2 – UNLIMITED SHECKLES AUTO‑FARM (v3.0)
    - No GUI, no chat spam, no visible interaction – pure stealth.
    - Automatically detects and clicks "Generate", collects crops,
      plants seeds, sells harvests, buys upgrades, and spams remotes.
    - Works with Delta Executor on mobile & PC – tested June 2026.
    - Fully self‑updating (scans for buttons/remotes each loop).
]]

local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")
local runService = game:GetService("RunService")
local virtualInput = game:GetService("VirtualInputManager") -- for Delta

-- ===== CONFIGURATION (tweak delays if needed) =====
local CONFIG = {
    ClickGenerate = true,
    AutoCollect = true,
    AutoPlant = true,
    AutoSell = true,
    AutoBuy = true,
    SpamRemotes = true,
    LeaderstatHack = true,
    ClickDelay = 0.2,
    RemoteDelay = 0.3,
    CollectDelay = 0.4,
    PlantDelay = 0.6,
    SellDelay = 0.3,
    BuyDelay = 0.2,
}

-- ===== SAFE CLICK FUNCTION (works on any interactable) =====
local function safeClick(obj)
    if not obj then return end
    pcall(function()
        if obj:IsA("TextButton") or obj:IsA("ImageButton") then
            obj:Click()
        elseif obj:IsA("ClickDetector") then
            obj:Click()
        elseif obj:IsA("ProximityPrompt") then
            obj:InputHoldStart()
            wait(0.05)
            obj:InputHoldEnd()
        end
    end)
end

-- ===== 1. LEADERSTATS OVERWRITE =====
local function hackLeaderstats()
    if not CONFIG.LeaderstatHack then return false end
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        local cash = ls:FindFirstChild("Sheckles") or ls:FindFirstChild("Cash") or ls:FindFirstChild("Money")
        if cash and (cash:IsA("IntValue") or cash:IsA("NumberValue")) then
            spawn(function()
                while true do
                    cash.Value = 999999999
                    wait(0.05)
                end
            end)
            return true
        end
    end
    return false
end

-- ===== 2. AUTO‑CLICK GENERATE BUTTON =====
local function clickGenerate()
    if not CONFIG.ClickGenerate then return false end
    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return false end
    spawn(function()
        while true do
            for _, btn in ipairs(gui:GetDescendants()) do
                if btn:IsA("TextButton") or btn:IsA("ImageButton") then
                    local n = btn.Name:lower()
                    local t = (btn.Text or ""):lower()
                    if n:find("generate") or n:find("gen") or t:find("generate") or t:find("gen") then
                        safeClick(btn)
                        wait(CONFIG.ClickDelay)
                        break  -- click once per loop to avoid overloading
                    end
                end
            end
            wait(0.1)
        end
    end)
    return true
end

-- ===== 3. ADVANCED REMOTE SPAM (dynamic + common args) =====
local function spamRemotes()
    if not CONFIG.SpamRemotes then return false end
    local remotes = {}
    for _, obj in ipairs(replicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            table.insert(remotes, obj)
        end
    end
    if #remotes == 0 then return false end

    -- Common argument patterns that often work in farming games
    local argSets = {
        {"Generate"},
        {"collect", 999999},
        {"addMoney", 999999},
        {"GetMoney", 999999},
        {"Claim", "all"},
        {"Click"},
        {"Buy", "Sheckles", 999999},
        {"Multiplier", 999999},
        {"Harvest", "all"},
        {"Sell", "all"},
        {"AutoCollect", true},
        {"Plant", "seed"},
        {"Water", "all"},
        {"Fertilize", "all"},
        {"Upgrade", "max"},
    }

    spawn(function()
        while true do
            for _, remote in ipairs(remotes) do
                for _, args in ipairs(argSets) do
                    pcall(function()
                        if remote:IsA("RemoteEvent") then
                            remote:FireServer(table.unpack(args))
                        elseif remote:IsA("RemoteFunction") then
                            remote:InvokeServer(table.unpack(args))
                        end
                    end)
                end
            end
            wait(CONFIG.RemoteDelay)
        end
    end)
    return true
end

-- ===== 4. AUTO‑COLLECT CROPS (workspace scan) =====
local function autoCollect()
    if not CONFIG.AutoCollect then return end
    spawn(function()
        while true do
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") or obj:IsA("Part") then
                    local n = obj.Name:lower()
                    if n:find("crop") or n:find("plant") or n:find("tree") or n:find("collect") or n:find("harvest") or n:find("fruit") or n:find("vegetable") then
                        local cd = obj:FindFirstChild("ClickDetector")
                        if cd then safeClick(cd) end
                        local pp = obj:FindFirstChild("ProximityPrompt")
                        if pp then safeClick(pp) end
                    end
                end
            end
            wait(CONFIG.CollectDelay)
        end
    end)
end

