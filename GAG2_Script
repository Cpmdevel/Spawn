-- ===== UTILITY =====
local function findDescendants(parent, className, predicate)
    local results = {}
    for _, obj in ipairs(parent:GetDescendants()) do
        if obj:IsA(className) and (not predicate or predicate(obj)) then
            table.insert(results, obj)
        end
    end
    return results
end

local function safeClick(obj)
    if not obj then return end
    pcall(function()
        if obj:IsA("TextButton") or obj:IsA("ImageButton") then
            obj:Click()
        elseif obj:IsA("ClickDetector") then
            obj:Click()
        elseif obj:IsA("ProximityPrompt") then
            obj:InputHoldStart()
            wait(0.1)
            obj:InputHoldEnd()
        end
    end)
end

-- ===== 1. LEADERSTATS HACK =====
local function hackLeaderstats()
    if not CONFIG.LeaderstatHack then return end
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        local cash = ls:FindFirstChild("Sheckles") or ls:FindFirstChild("Cash") or ls:FindFirstChild("Money")
        if cash and (cash:IsA("IntValue") or cash:IsA("NumberValue")) then
            spawn(function()
                while true do
                    cash.Value = 999999999
                    wait(0.1)
                end
            end)
            return true
        end
    end
    return false
end

-- ===== 2. AUTO‑CLICK GENERATE =====
local function clickGenerate()
    if not CONFIG.ClickGenerate then return end
    local gui = player:FindFirstChild("PlayerGui")
    if not gui then return end
    local btn = nil
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("TextButton") or obj:IsA("ImageButton") then
            local n = obj.Name:lower()
            local t = (obj.Text or ""):lower()
            if n:find("generate") or n:find("gen") or t:find("generate") or t:find("gen") then
                btn = obj
                break
            end
        end
    end
    if btn then
        spawn(function()
            while true do
                safeClick(btn)
                wait(CONFIG.ClickDelay)
            end
        end)
        return true
    end
    return false
end

-- ===== 3. REMOTE SPAM =====
local function spamRemotes()
    if not CONFIG.RemoteSpam then return end
    local remotes = findDescendants(replicatedStorage, "RemoteEvent")
    local funcs = findDescendants(replicatedStorage, "RemoteFunction")
    if #remotes == 0 and #funcs == 0 then return false end

    local argsList = {
        {"Generate"},
        {"collect", 999999},
        {"addMoney", 999999},
        {"GetMoney", 999999},
        {"Claim", "all"},
        {"Click"},
        {"Buy", "Sheckles", 999999},
        {"Multiplier", 999999},
        {"Harvest", "all"},
        {"Sell", "all"},
        {"AutoCollect", true},
        {"Garden", "collect"},
        {"Plant", "seed"},
        {"Water", "all"},
    }

    spawn(function()
        while true do
            for _, remote in ipairs(remotes) do
                for _, args in ipairs(argsList) do
                    pcall(remote.FireServer, remote, table.unpack(args))
                end
            end
            for _, func in ipairs(funcs) do
                for _, args in ipairs(argsList) do
                    pcall(func.InvokeServer, func, table.unpack(args))
                end
            end
            wait(CONFIG.RemoteDelay)
        end
    end)
    return true
end

