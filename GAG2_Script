-- ===== 🔥 ENHANCED AUTO‑BUY (now works on ALL shop items) =====
local function autoBuy()
    if not CONFIG.AutoBuy then return end
    spawn(function()
        while true do
            local gui = player:FindFirstChild("PlayerGui")
            if gui then
                -- Scan every single button in the entire GUI
                for _, btn in ipairs(gui:GetDescendants()) do
                    if btn:IsA("TextButton") or btn:IsA("ImageButton") then
                        local t = (btn.Text or ""):lower()
                        local n = btn.Name:lower()
                        
                        -- Catch all possible buy/upgrade/purchase/unlock buttons
                        if t:find("buy") or t:find("purchase") or t:find("upgrade") or 
                           t:find("unlock") or t:find("get") or t:find("claim") or
                           n:find("buy") or n:find("purchase") or n:find("upgrade") or 
                           n:find("unlock") or n:find("shop") or n:find("store") then
                            
                            -- Also check if the button is visible (optional)
                            local visible = true
                            if btn:IsA("GuiButton") and btn.Active then
                                -- Some games disable buttons when you can't afford; we still click
                            end
                            safeClick(btn)
                            wait(CONFIG.BuyDelay)
                        end
                    end
                end
                
                -- Also specifically target shop frames/items
                for _, frame in ipairs(gui:GetDescendants()) do
                    if frame:IsA("Frame") or frame:IsA("ScrollingFrame") then
                        local fname = frame.Name:lower()
                        if fname:find("shop") or fname:find("store") or fname:find("upgrade") or fname:find("item") then
                            for _, child in ipairs(frame:GetDescendants()) do
                                if child:IsA("TextButton") or child:IsA("ImageButton") then
                                    safeClick(child)
                                    wait(CONFIG.BuyDelay)
                                end
                            end
                        end
                    end
                end
            end
            wait(0.3) -- fast loop to catch all items
        end
    end)
end

