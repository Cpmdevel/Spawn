-- 1. TRY TO SET CASH VIA LEADERSTATS
local function setLeaderstatsCash()
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        local cash = ls:FindFirstChild("Sheckles") or ls:FindFirstChild("Cash") or ls:FindFirstChild("Money")
        if cash then
            print("[GAG2] Found cash in leaderstats. Setting to max.")
            while true do
                cash.Value = 9e9  -- 9 billion
                wait(0.1)
            end
        end
    end
end

-- 2. AUTO-CLICK THE GENERATE BUTTON
local function autoGenerate()
    local gui = player.PlayerGui
    local generateBtn
    -- Search all descendants for a TextButton containing "Generate" in its name/text
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("TextButton") then
            local name = obj.Name:lower()
            local text = (obj.Text or ""):lower()
            if name:find("generate") or text:find("generate") then
                generateBtn = obj
                break
            end
        end
    end
    if generateBtn then
        print("[GAG2] Generate button found. Auto-clicking...")
        spawn(function()
            while true do
                generateBtn:Click()
                wait(0.3)  -- adjust delay to avoid throttling
            end
        end)
    else
        warn("[GAG2] Generate button not found.")
    end
end

-- 3. ATTEMPT REMOTE EVENT SPAM (common in many games)
local function spamRemote()
    local remote = replicatedStorage:FindFirstChild("RemoteEvent") or 
                   replicatedStorage:FindFirstChild("GiveMoney") or
                   game:GetService("ReplicatedStorage"):FindFirstChild("SheckleEvent")
    if remote and remote:IsA("RemoteEvent") then
        print("[GAG2] Found remote event. Spamming...")
        spawn(function()
            while true do
                -- Try common arguments; you may need to inspect the game to find correct ones
                remote:FireServer("Generate", "collect", "claim")
                remote:FireServer("getMoney", 999999)
                remote:FireServer("addSheckles", 999999)
                wait(0.5)
            end
        end)
    else
        warn("[GAG2] No suitable remote event found.")
    end
end

-- 4. COLLECT ALL FARMABLE ITEMS (if any)
local function autoCollect()
    -- Look for objects with "Collect" or "Harvest" in name and click them
    spawn(function()
        while true do
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") or obj:IsA("Part") then
                    if obj.Name:lower():find("collect") or obj.Name:lower():find("harvest") or obj.Name:lower():find("crop") then
                        local clickable = obj:FindFirstChild("ClickDetector") or obj:FindFirstChild("ProximityPrompt")
                        if clickable then
                            if clickable:IsA("ClickDetector") then
                                clickable:Click()
                            elseif clickable:IsA("ProximityPrompt") then
                                clickable:InputHoldStart()
                                wait(0.2)
                                clickable:InputHoldEnd()
                            end
                        end
                    end
                end
            end
            wait(1)
        end
    end)
end

