-- ===== TAB SWITCHING =====
for i, name in ipairs(tabs) do
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1/#tabs, -2, 1, -2)
    btn.Position = UDim2.new((i-1)/#tabs, 1, 0, 1)
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 14
    btn.BorderSizePixel = 0
    btn.Parent = tabContainer
    tabButtons[name] = btn

    btn.MouseButton1Click:Connect(function()
        -- Hide all content frames
        for _, child in pairs(contentFrame:GetChildren()) do
            if child:IsA("Frame") then
                child.Visible = false
            end
        end
        -- Show selected
        local tabFrame = contentFrame:FindFirstChild(name .. "Tab")
        if tabFrame then tabFrame.Visible = true end
        -- Highlight button
        for _, b in pairs(tabButtons) do
            b.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
        end
        btn.BackgroundColor3 = Color3.fromRGB(100, 100, 150)
    end)
end

-- Show first tab by default
